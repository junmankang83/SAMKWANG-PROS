// SAMKWANG-PROS Prisma 스키마

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SparePartLedgerEntryType {
  INBOUND
  OUTBOUND
}

/// 시스템 사용자 (회원가입)
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String   @default("")
  passwordHash String
  organization String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 설비정보 (기준정보)
model Tool {
  id             String    @id @default(cuid())
  toolSeq        Int       @unique
  toolName       String    @db.VarChar(50)
  toolNo         String    @db.VarChar(30)
  spec           String?   @db.VarChar(60)
  smStatus       Int?
  smStatusNm     String?   @db.VarChar(200)
  umToolKind     Int?
  umToolKindName String?   @db.VarChar(40)
  assetSeq       Int?
  asstName       String?   @db.VarChar(100)
  asstNo         String?   @db.VarChar(30)
  deptSeq        Int?
  deptName       String?   @db.VarChar(200)
  empSeq         Int?
  empName        String?   @db.VarChar(200)
  empid          String?   @db.VarChar(40)
  lastUserName   String?   @db.VarChar(200)
  lastDateTime   DateTime?
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sparePartMasters SparePartMaster[]
  ledgerEntries    SparePartLedgerEntry[]

  @@index([isActive, sortOrder])
  @@index([umToolKind])
  @@index([toolName])
}

/// 사출기 예비부품 기초정보 (기준정보)
model SparePartMaster {
  id              String   @id @default(cuid())
  partCode        String   @unique @db.VarChar(50)
  machineBrand    String   @db.VarChar(100)
  toolId          String?
  tool            Tool?    @relation(fields: [toolId], references: [id], onDelete: SetNull)
  productName     String   @db.VarChar(200)
  spec            String?  @db.VarChar(200)
  unit            String   @default("EA") @db.VarChar(20)
  optimalQty      Decimal  @default(0) @db.Decimal(14, 4)
  manufacturer    String?  @db.VarChar(100)
  storageLocation String?  @db.VarChar(100)
  leadTimeDays    Int?
  remarks         String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdBy       String?  @db.VarChar(100)
  updatedBy       String?  @db.VarChar(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items SparePartItem[]

  @@index([machineBrand, productName])
  @@index([isActive, sortOrder])
  @@index([toolId])
}

/// 사출기 예비부품 입출고 행
model SparePartItem {
  id            String   @id @default(cuid())
  masterId      String?
  master        SparePartMaster? @relation(fields: [masterId], references: [id], onDelete: SetNull)
  machineBrand  String
  productName   String
  spec          String?
  optimalQty    Decimal  @default(0) @db.Decimal(14, 4)
  currentQty    Decimal  @default(0) @db.Decimal(14, 4)
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ledgerEntries SparePartLedgerEntry[]

  @@index([machineBrand, productName])
  @@index([masterId])
}

/// 입출고 이력
model SparePartLedgerEntry {
  id               String                    @id @default(cuid())
  itemId           String
  item             SparePartItem             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  toolId           String?
  tool             Tool?                     @relation(fields: [toolId], references: [id], onDelete: SetNull)
  toolNameSnapshot String?                   @db.VarChar(50)
  type             SparePartLedgerEntryType
  qty              Decimal                   @db.Decimal(14, 4)
  occurredAt       DateTime
  note             String?
  createdAt        DateTime                  @default(now())

  @@index([itemId, occurredAt])
  @@index([toolId])
}

/// 월별 관리대장 결재 기록 (YYYY-MM 단위)
model SparePartLedgerPeriod {
  id          String    @id @default(cuid())
  periodMonth String    @unique
  preparedBy  String?
  preparedAt  DateTime?
  reviewedBy  String?
  reviewedAt  DateTime?
  confirmedBy String?
  confirmedAt DateTime?
  teamLeadBy  String?
  teamLeadAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

/// 설비관리 — 기준정보관리 상위 코드
model MoldCodeGroup {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(200)
  category    String   @default("") @db.VarChar(100)
  description String   @default("") @db.VarChar(500)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items MoldCodeItem[]

  @@index([sortOrder, code])
}

/// 설비관리 — 기준정보관리 하위 코드 (상위 1건에 종속)
model MoldCodeItem {
  id          String   @id @default(cuid())
  groupId     String
  group       MoldCodeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(200)
  category    String   @default("") @db.VarChar(100)
  description String   @default("") @db.VarChar(500)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([groupId, code])
  @@index([groupId, sortOrder, code])
  inspectionCategoryFor MoldInspectionItem[] @relation("InspectionCategoryItem")
  inspectionTypeFor MoldInspectionItem[] @relation("InspectionTypeItem")
  inspectionPlans MoldInspectionPlan[]
}

/// 설비관리 — 점검항목 (설비구분·유형별)
model MoldInspectionItem {
  id                  String   @id @default(cuid())
  categoryItemId      String
  categoryItem        MoldCodeItem @relation("InspectionCategoryItem", fields: [categoryItemId], references: [id], onDelete: Cascade)
  typeItemId          String?
  typeItem            MoldCodeItem? @relation("InspectionTypeItem", fields: [typeItemId], references: [id], onDelete: SetNull)
  inspectionCategory  String   @default("") @db.VarChar(500)
  itemCode            String   @db.VarChar(50)
  itemName            String   @db.VarChar(500)
  method              String   @default("") @db.Text
  detail              String   @default("") @db.Text
  criteria            String   @default("") @db.Text
  cycle               String   @default("") @db.VarChar(300)
  remarks             String   @default("") @db.Text
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([categoryItemId, itemCode])
  @@index([categoryItemId, typeItemId, sortOrder])
}

/// 설비구분·연도별 점검 계획 (월별 계획·실적 주차는 JSON)
model MoldInspectionPlan {
  id             String   @id @default(cuid())
  categoryItemId String
  categoryItem   MoldCodeItem @relation(fields: [categoryItemId], references: [id], onDelete: Cascade)
  year           Int
  /// { "점검항목id": { "1": 2, "12": 5 } } 월 1~12 → 계획 주차 1~5 또는 생략/null
  planJson       Json     @default("{}")
  /// 동일 구조, 실적 주차
  actualJson     Json     @default("{}")
  /// 항목별 비고(remarks)·점검내용(inspectionNotes) 등 실적 화면 전용 메타
  recordMetaJson Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([categoryItemId, year])
  @@index([year, categoryItemId])
}
