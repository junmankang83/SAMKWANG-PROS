// SAMKWANG-PROS Prisma 스키마

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SparePartLedgerEntryType {
  INBOUND
  OUTBOUND
}

/// 시스템 사용자 (회원가입)
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String   @default("")
  passwordHash String
  organization String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 설비정보 (기준정보)
model Tool {
  id             String    @id @default(cuid())
  toolSeq        Int       @unique
  toolName       String    @db.VarChar(50)
  toolNo         String    @db.VarChar(30)
  spec           String?   @db.VarChar(60)
  smStatus       Int?
  smStatusNm     String?   @db.VarChar(200)
  umToolKind     Int?
  umToolKindName String?   @db.VarChar(40)
  assetSeq       Int?
  asstName       String?   @db.VarChar(100)
  asstNo         String?   @db.VarChar(30)
  deptSeq        Int?
  deptName       String?   @db.VarChar(200)
  empSeq         Int?
  empName        String?   @db.VarChar(200)
  empid          String?   @db.VarChar(40)
  lastUserName   String?   @db.VarChar(200)
  lastDateTime   DateTime?
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sparePartMasters SparePartMaster[]
  ledgerEntries    SparePartLedgerEntry[]

  @@index([isActive, sortOrder])
  @@index([umToolKind])
  @@index([toolName])
}

/// 사출기 예비부품 기초정보 (기준정보)
model SparePartMaster {
  id              String   @id @default(cuid())
  partCode        String   @unique @db.VarChar(50)
  machineBrand    String   @db.VarChar(100)
  toolId          String?
  tool            Tool?    @relation(fields: [toolId], references: [id], onDelete: SetNull)
  productName     String   @db.VarChar(200)
  spec            String?  @db.VarChar(200)
  unit            String   @default("EA") @db.VarChar(20)
  optimalQty      Decimal  @default(0) @db.Decimal(14, 4)
  manufacturer    String?  @db.VarChar(100)
  storageLocation String?  @db.VarChar(100)
  leadTimeDays    Int?
  remarks         String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdBy       String?  @db.VarChar(100)
  updatedBy       String?  @db.VarChar(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items SparePartItem[]

  @@index([machineBrand, productName])
  @@index([isActive, sortOrder])
  @@index([toolId])
}

/// 사출기 예비부품 입출고 행
model SparePartItem {
  id            String   @id @default(cuid())
  masterId      String?
  master        SparePartMaster? @relation(fields: [masterId], references: [id], onDelete: SetNull)
  machineBrand  String
  productName   String
  spec          String?
  optimalQty    Decimal  @default(0) @db.Decimal(14, 4)
  currentQty    Decimal  @default(0) @db.Decimal(14, 4)
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ledgerEntries SparePartLedgerEntry[]

  @@index([machineBrand, productName])
  @@index([masterId])
}

/// 입출고 이력
model SparePartLedgerEntry {
  id               String                    @id @default(cuid())
  itemId           String
  item             SparePartItem             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  toolId           String?
  tool             Tool?                     @relation(fields: [toolId], references: [id], onDelete: SetNull)
  toolNameSnapshot String?                   @db.VarChar(50)
  type             SparePartLedgerEntryType
  qty              Decimal                   @db.Decimal(14, 4)
  occurredAt       DateTime
  note             String?
  createdAt        DateTime                  @default(now())

  @@index([itemId, occurredAt])
  @@index([toolId])
}

/// 월별 관리대장 결재 기록 (YYYY-MM 단위)
model SparePartLedgerPeriod {
  id          String    @id @default(cuid())
  periodMonth String    @unique
  preparedBy  String?
  preparedAt  DateTime?
  reviewedBy  String?
  reviewedAt  DateTime?
  confirmedBy String?
  confirmedAt DateTime?
  teamLeadBy  String?
  teamLeadAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

/// 설비관리 — 기준정보관리 상위 코드
model MoldCodeGroup {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(200)
  category    String   @default("") @db.VarChar(100)
  description String   @default("") @db.VarChar(500)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items MoldCodeItem[]

  @@index([sortOrder, code])
}

/// 설비관리 — 기준정보관리 하위 코드 (상위 1건에 종속)
model MoldCodeItem {
  id          String   @id @default(cuid())
  groupId     String
  group       MoldCodeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(200)
  category    String   @default("") @db.VarChar(100)
  description String   @default("") @db.VarChar(500)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([groupId, code])
  @@index([groupId, sortOrder, code])
  inspectionCategoryFor MoldInspectionItem[] @relation("InspectionCategoryItem")
  inspectionTypeFor MoldInspectionItem[] @relation("InspectionTypeItem")
  inspectionPlans MoldInspectionPlan[]
}

/// 설비관리 — 점검항목 (설비구분·유형별)
model MoldInspectionItem {
  id                  String   @id @default(cuid())
  categoryItemId      String
  categoryItem        MoldCodeItem @relation("InspectionCategoryItem", fields: [categoryItemId], references: [id], onDelete: Cascade)
  typeItemId          String?
  typeItem            MoldCodeItem? @relation("InspectionTypeItem", fields: [typeItemId], references: [id], onDelete: SetNull)
  inspectionCategory  String   @default("") @db.VarChar(500)
  itemCode            String   @db.VarChar(50)
  itemName            String   @db.VarChar(500)
  method              String   @default("") @db.Text
  detail              String   @default("") @db.Text
  criteria            String   @default("") @db.Text
  cycle               String   @default("") @db.VarChar(300)
  remarks             String   @default("") @db.Text
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([categoryItemId, itemCode])
  @@index([categoryItemId, typeItemId, sortOrder])
}

/// 설비구분·연도별 점검 계획 (월별 계획·실적 주차는 JSON)
model MoldInspectionPlan {
  id             String   @id @default(cuid())
  categoryItemId String
  categoryItem   MoldCodeItem @relation(fields: [categoryItemId], references: [id], onDelete: Cascade)
  year           Int
  /// { "점검항목id": { "1": 2, "12": 5 } } 월 1~12 → 계획 주차 1~5 또는 생략/null
  planJson       Json     @default("{}")
  /// 동일 구조, 실적 주차
  actualJson     Json     @default("{}")
  /// 항목별 비고(remarks)·점검내용(inspectionNotes) 등 실적 화면 전용 메타
  recordMetaJson Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([categoryItemId, year])
  @@index([year, categoryItemId])
}

enum MailScheduleType {
  DAILY
  CRON
}

enum MailSendLogStatus {
  SUCCESS
  FAILURE
}

/// SMTP 발신 프로필 (여러 건 등록, 발송 규칙에서 선택)
model MailSmtpProfile {
  id             String   @id @default(cuid())
  name           String   @db.VarChar(200)
  host           String   @default("") @db.VarChar(255)
  port           Int      @default(587)
  secure         Boolean  @default(false)
  user           String   @default("") @db.VarChar(255)
  passwordCipher String   @default("") @db.Text
  fromName       String   @default("") @db.VarChar(200)
  fromAddress    String   @default("") @db.VarChar(255)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sendRules MailSendRule[]
  mailMenus MailMenu[]

  @@index([sortOrder])
}

/// 메일발송메뉴 — 템플릿(종류) 정의
model MailMenu {
  id              String   @id @default(cuid())
  code            String   @unique @db.VarChar(80)
  label           String   @db.VarChar(200)
  defaultSubject  String   @default("") @db.VarChar(500)
  defaultBody     String   @default("") @db.Text
  sortOrder       Int      @default(0)
  /// 메뉴별 조회/발송용 긴 쿼리·텍스트
  menuQuery       String   @default("") @db.Text
  /// 수신 이메일 문자열 배열 JSON
  recipientEmails Json     @default("[]")
  /// 비트마스크: bit0=일 … bit6=토 (MailSendRule.dailyDaysMask 와 동일)
  sendDaysMask    Int      @default(127)
  /// "HH:mm" 문자열 배열 JSON
  sendTimes       Json     @default("[]")
  /// 메뉴 기준 자동 발송에 사용할 SMTP 프로필(비우면 연결된 규칙의 프로필 순)
  mailSmtpProfileId String?
  mailSmtpProfile    MailSmtpProfile? @relation(fields: [mailSmtpProfileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// 메뉴 기준 자동 발송 마지막 처리 분(UTC) — 중복 방지
  lastMenuSendSlotUtc DateTime?
  /// 저장된 요일·시각에 스케줄러 자동 발송 사용 여부(끄면 시간이 와도 발송하지 않음)
  scheduleAutoSendEnabled Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sendRules MailSendRule[]
  sendLogs  MailMenuSendLog[]

  @@index([mailSmtpProfileId])
}

/// 메일 메뉴 기준 자동 발송 이력 (MailSendLog 와 별도)
model MailMenuSendLog {
  id             String            @id @default(cuid())
  mailMenuId     String
  mailMenu       MailMenu          @relation(fields: [mailMenuId], references: [id], onDelete: Cascade)
  sentAt         DateTime          @default(now())
  status         MailSendLogStatus
  errorMessage   String?           @db.Text
  smtpMessageId  String?           @db.VarChar(255)
  /// 발송 시점 수신자 목록(JSON 문자열 배열)
  toAddressesSnapshot Json?
  /// HTML 본문 내 추적 픽셀용 비밀 토큰(미설정 시 텍스트만 발송)
  openTrackingToken String?        @unique @db.VarChar(64)
  /// 수신 클라이언트가 픽셀 URL을 최초 요청한 시각(이미지 차단 시 기록 없음)
  firstOpenedAt  DateTime?
  openCount      Int               @default(0)

  @@index([mailMenuId, sentAt])
}

/// 메일발송정보 — 스케줄·수신·본문
model MailSendRule {
  id             String           @id @default(cuid())
  enabled        Boolean          @default(true)
  name           String           @db.VarChar(200)
  scheduleType   MailScheduleType @default(DAILY)
  /// CRON 모드일 때 (Asia/Seoul 기준 5필드)
  cronExpression String?          @db.VarChar(120)
  /// DAILY 모드일 때 "HH:mm"
  dailyTime      String?          @db.VarChar(5)
  /// 비트마스크: bit0=일 … bit6=토 (1이면 해당 요일 발송)
  dailyDaysMask  Int              @default(127)
  /// 수신 이메일 문자열 배열 JSON
  toAddresses    Json             @default("[]")
  subject        String           @default("") @db.VarChar(500)
  body           String           @default("") @db.Text
  mailMenuId     String?
  mailMenu       MailMenu?        @relation(fields: [mailMenuId], references: [id], onDelete: SetNull)
  mailSmtpProfileId String
  mailSmtpProfile   MailSmtpProfile @relation(fields: [mailSmtpProfileId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /// 마지막으로 발송 처리한 분 슬롯(UTC) — 중복 방지
  lastRunSlotUtc DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  logs MailSendLog[]

  @@index([enabled])
  @@index([mailMenuId])
  @@index([mailSmtpProfileId])
}

/// 발송 이력
model MailSendLog {
  id            String            @id @default(cuid())
  ruleId        String
  rule          MailSendRule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  sentAt        DateTime          @default(now())
  status        MailSendLogStatus
  errorMessage  String?           @db.Text
  smtpMessageId String?           @db.VarChar(255)
  /// 발송 시점 수신자 목록(JSON 문자열 배열)
  toAddressesSnapshot Json?
  openTrackingToken String?       @unique @db.VarChar(64)
  firstOpenedAt DateTime?
  openCount     Int               @default(0)

  @@index([ruleId, sentAt])
}
