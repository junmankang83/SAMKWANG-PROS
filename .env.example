# ────────────────────────────────────────────────
# SAMKWANG-PROS 환경 변수 템플릿
# 사용법: cp .env.example .env  (이후 값 변경)
# ────────────────────────────────────────────────

# Compose 프로젝트 이름 (컨테이너·네트워크 접두사)
COMPOSE_PROJECT_NAME=samkwang-pros

# ── PostgreSQL ──
POSTGRES_USER=samkwang
POSTGRES_PASSWORD=samkwang_dev
POSTGRES_DB=samkwang_pros
POSTGRES_PORT=5432

# Docker 가 호스트에 바인딩할 주소 (외부 접속: 0.0.0.0, 호스트 로컬만: 127.0.0.1)
APP_PUBLISH_HOST=0.0.0.0

# ── Backend (NestJS) ──
BACKEND_PORT=4000
APP_VERSION=0.1.0
# 브라우저에서 접속하는 주소 Origin (gateway 한 포트 기준). 콤마로 여러 개 가능.
# 예: CORS_ORIGIN=http://localhost:3000,http://192.168.0.10:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000

# ── 웹 진입점 (nginx: / → 프론트, /api → 백엔드) ──
# 호스트 3000이 이미 사용 중이면(예: Nest 단독 실행) 3080 등으로 바꾸고 CORS_ORIGIN·PUBLIC_APP_BASE 포트도 같이 수정
APP_WEB_PORT=3000
# 브라우저에서 접속하는 웹 앱 베이스 URL (예: http://192.168.0.10:3000). 백엔드에 / 로 들어왔을 때 프론트로 리다이렉트할 때 사용합니다.
PUBLIC_APP_BASE=

# ── 목업 로그인 / 세션 (백엔드) ──
SESSION_SECRET=change-me-to-a-long-random-string
DEMO_AUTH_USERNAME=demo
DEMO_AUTH_PASSWORD=demo

# Next 서버에서 백엔드로 직접 호출 (서버 컴포넌트 세션 확인 등). Docker frontend: http://backend:4000
BACKEND_INTERNAL_URL=http://127.0.0.1:4000
# 로컬에서 next dev만 띄울 때 /api 를 백엔드로 프록시 (next.config.mjs)
BACKEND_PROXY_TARGET=http://127.0.0.1:4000
# frontend/.next 가 쓰기 불가할 때 프로덕션 빌드: NEXT_DIST_DIR=.next-build pnpm --filter @samkwang/frontend build
# NEXT_DIST_DIR=.next-build

# ── 비고 ──
# 프론트 핫 리로드(Fast Refresh) 개발: pnpm compose:dev  (또는 docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build)
# 파일 감지가 안 되면 WATCHPACK_POLLING=true 를 .env 에 추가
# DATABASE_URL 은 docker-compose.yml 에서 위 값으로 자동 조립됩니다.
# 컨테이너 외부(로컬 Node)에서 백엔드를 직접 실행할 때만 별도 설정:
#   DATABASE_URL=postgresql://samkwang:samkwang_dev@localhost:5432/samkwang_pros?schema=public
