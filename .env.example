# ────────────────────────────────────────────────
# SAMKWANG-PROS 환경 변수 템플릿
# 사용법: cp .env.example .env  (이후 값 변경)
# ────────────────────────────────────────────────

# Compose 프로젝트 이름 (컨테이너·네트워크 접두사)
COMPOSE_PROJECT_NAME=samkwang-pros

# ── PostgreSQL ──
POSTGRES_USER=samkwang
POSTGRES_PASSWORD=samkwang_dev
POSTGRES_DB=samkwang_pros
POSTGRES_PORT=5432

# Docker 가 호스트에 바인딩할 주소 (외부 접속: 0.0.0.0, 호스트 로컬만: 127.0.0.1)
APP_PUBLISH_HOST=0.0.0.0

# ── Backend (NestJS) ──
BACKEND_PORT=4000
APP_VERSION=0.1.0
# 브라우저에서 접속하는 주소 Origin (gateway 한 포트 기준). 콤마로 여러 개 가능.
# 예: CORS_ORIGIN=http://localhost:3000,http://192.168.0.10:3000,https://app.example.com
CORS_ORIGIN=http://localhost:3000

# ── 웹 진입점 (nginx: / → 프론트, /api → 백엔드) ──
# 호스트 3000이 이미 사용 중이면(예: Nest 단독 실행) 3080 등으로 바꾸고 CORS_ORIGIN·PUBLIC_APP_BASE 포트도 같이 수정
APP_WEB_PORT=3000
# 브라우저에서 접속하는 웹 앱 베이스 URL (예: http://192.168.0.10:3000). 백엔드에 / 로 들어왔을 때 프론트로 리다이렉트할 때 사용합니다.
PUBLIC_APP_BASE=

# 메일 열람 추적 픽셀 URL에 쓰는 공개 API 베이스(선택). 비우면 아래 순으로 추정합니다.
# 우선순위: MAIL_TRACKING_PUBLIC_URL → PUBLIC_APP_BASE → FRONTEND_PUBLIC_URL → BACKEND_PUBLIC_URL → CORS_ORIGIN 첫 항목 + /api
# 수신자 메일 클라이언트가 접근 가능해야 하므로 nginx 게이트웨이 등 외부 URL을 권장합니다. 예: http://192.168.0.10:3000/api
MAIL_TRACKING_PUBLIC_URL=
# 웹 앱만 따로 둘 때(비우면 PUBLIC_APP_BASE·CORS 등으로 대체)
FRONTEND_PUBLIC_URL=
# 메일 수신자가 백엔드(:4000)를 직접 호출할 수 있는 공개 URL이 있을 때만. 예: https://api.example.com
BACKEND_PUBLIC_URL=

# ── 목업 로그인 / 세션 (백엔드) ──
SESSION_SECRET=change-me-to-a-long-random-string
DEMO_AUTH_USERNAME=demo
DEMO_AUTH_PASSWORD=demo

# Next 서버에서 백엔드로 직접 호출 (서버 컴포넌트 세션 확인 등). Docker frontend: http://backend:4000
BACKEND_INTERNAL_URL=http://127.0.0.1:4000
# 로컬에서 next dev만 띄울 때 /api 를 백엔드로 프록시 (next.config.mjs)
BACKEND_PROXY_TARGET=http://127.0.0.1:4000
# frontend/.next 가 쓰기 불가할 때 프로덕션 빌드: NEXT_DIST_DIR=.next-build pnpm --filter @samkwang/frontend build
# NEXT_DIST_DIR=.next-build

# ── 비고 ──
# 프론트 핫 리로드(Fast Refresh) 개발: pnpm compose:dev  (또는 docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build)
# 파일 감지가 안 되면 WATCHPACK_POLLING=true 를 .env 에 추가
# DATABASE_URL 은 docker-compose.yml 에서 위 값으로 자동 조립됩니다.
# 컨테이너 외부(로컬 Node)에서 백엔드를 직접 실행할 때만 별도 설정:
#   DATABASE_URL=postgresql://samkwang:samkwang_dev@localhost:5432/samkwang_pros?schema=public

# ── 메일 (SMTP 비밀번호 AES-256-GCM 암호화 키 소스) ──
# 임의의 긴 문자열을 권장합니다. 비어 있으면 내장 기본값(개발용)이 사용됩니다.
MAIL_ENCRYPTION_KEY=

# ── ERP MSSQL (설비정보 동기화: KN_View_TPDTool) ──
ERP_MSSQL_HOST=192.168.1.42
ERP_MSSQL_PORT=14233
ERP_MSSQL_DATABASE=SKKR
ERP_MSSQL_USER=skkrerp
ERP_MSSQL_PASSWORD=your-erp-mssql-password
ERP_MSSQL_ENCRYPT=false
ERP_MSSQL_TRUST_SERVER_CERT=true
# 창고별수불 프로시저(skkr_SWLGWHStockSumListQuery) 전용 계정 — 비우면 ERP_MSSQL_USER로 폴백
# USER2 SQL 로그인은 skkrace 권장. OS 환경 변수에 skkracc 오타가 있어도 백엔드에서 skkrace로 보정합니다.
ERP_MSSQL_USER2=
ERP_MSSQL_PASSWORD2=
# PASSWORD2에 #·$ 가 있으면 큰따옴표 필수(그렇지 않으면 #부터 잘림). 끝이 $이면 따옴표 안에서 \ 로 이스케이프 예: "secret#x\$"
# 거래명세 품목 조회: ERP 클라이언트와 동일한 법인·사업장 범위로 제한 (비우면 전체 CompanySeq)
ERP_TSL_INVOICE_COMPANY_SEQ=
ERP_TSL_INVOICE_BIZ_UNIT=
# 일자별판매실적분석(_TSLInvoiceItem·_TSLSalesItem·_TSLBillItem): 법인 한정 (비우면 ERP_TSL_INVOICE_COMPANY_SEQ 사용, 그것도 비우면 전체 CompanySeq)
ERP_TSL_SALES_ANALYSIS_COMPANY_SEQ=
# 작업실적조회(_TPDSFCWorkReport): 법인 한정 (비우거나 0이면 전체 CompanySeq, 1 이상일 때만 필터)
ERP_PDSFC_WORK_REPORT_COMPANY_SEQ=
# 반품요청 품목 조회(_TSLDVReq·_TSLDVReqItem): 법인·사업장 한정 (비우면 전체 CompanySeq)
ERP_TSL_DV_REQ_COMPANY_SEQ=
ERP_TSL_DV_REQ_BIZ_UNIT=
# 수출반품: UMOutKind = _TDAUMinorValue MinorSeq (8020·2002·ValueText 1) — 기본. UM만 끄려면 true
# ERP_TSL_EXPORT_RETURN_SKIP_UM_OUT_KIND_FILTER=
# 수출반품: _TSLInvoice.SMExpKind = 8009019 — 기본. SM만 끄려면 true
# ERP_TSL_EXPORT_RETURN_SKIP_SM_EXP_KIND_FILTER=
# 구매입고/반품 품목 조회: 법인·사업장 한정 (비우면 전체 CompanySeq)
ERP_PU_DELV_IN_COMPANY_SEQ=
ERP_PU_DELV_IN_BIZ_UNIT=
# 외주입고/반품 품목(_TPDOSPDelvIn) 조회 시 법인·사업장(비우면 ERP_PU_DELV_IN_* 로 폴백)
ERP_OSP_DELV_IN_COMPANY_SEQ=
ERP_OSP_DELV_IN_BIZ_UNIT=
# 납품/반품 구분: _TDAUMinorValue 조인 시 MajorSeq·Serl까지 맞춰야 할 때만 둘 다 설정(ERP에서 소분류 그룹 확인)
# ERP_OSP_DELV_IN_KIND_UMINOR_MAJOR=
# ERP_OSP_DELV_IN_KIND_UMINOR_SERL=
# 납품반품구분: _TPDOSPDelvIn.SMDelvType → _TDASMinor MajorSeq (기본 6209). 다른 코드면 설정.
# ERP_OSP_DELV_IN_SMDELVTYPE_UMINOR_MAJOR=
# 구매납품 품목 조회 시 법인·사업장 필터(비우면 전체)
ERP_PU_DELV_COMPANY_SEQ=
ERP_PU_DELV_BIZ_UNIT=
# 외주납품 품목(TPDOSPDelv) 조회 시 법인·사업장(비우면 ERP_PU_DELV_* 로 폴백 가능 — 서비스 구현 기준)
ERP_OSP_DELV_COMPANY_SEQ=
ERP_OSP_DELV_BIZ_UNIT=
# 일별수불 이동품목(_TLGInoutDaily, InOutType=80) — 비우면 ERP_PU_DELV_IN_* 로 폴백
ERP_LG_INOUT_COMPANY_SEQ=
ERP_LG_INOUT_BIZ_UNIT=
# 창고별수불집계: Sp_StockSumListQuery_NQL @BegDate,@EndDate (YYYYMMDD 8자). 사용하려면 true
ERP_WH_STOCK_SUM_USE_SP_STOCK_SUM_LIST_QUERY_NQL=true
# ERP_WH_STOCK_SUM_SP_STOCK_SUM_LIST_QUERY_NQL_PROC=Sp_StockSumListQuery_NQL
# SP 매개 변수명이 다르면(예: DateFr/DateTo) 아래만 맞춤
# ERP_WH_STOCK_SUM_SP_NQL_DATE_FR_PARAM=BegDate
# ERP_WH_STOCK_SUM_SP_NQL_DATE_TO_PARAM=EndDate
# 창고별수불집계: 기본은 _TLGInoutDaily·Item 직접 집계(프로시저 EXECUTE 불필요). ERP 프로시저만 쓰려면 true
# ERP_WH_STOCK_SUM_USE_ERP_PROC=false
# 직접 집계 시 이월 재고용 과거 스캔 일수(기본 1460). 늘리면 부하 증가
# ERP_WH_STOCK_SUM_DIRECT_OPENING_LOOKBACK_DAYS=1460
# 프로시저 경로 전용: 법인·사업장·집계코드 등(직접 집계에도 CompanySeq·BizUnit·표시용 SM* 파라미터로 사용)
# ERP_WH_STOCK_SUM_COMPANY_SEQ=1
# ERP_WH_STOCK_SUM_BIZ_UNIT=1
# ERP_WH_STOCK_SUM_RUN_PROC_CHECK=false
# 창고별 재고조회 — ERP_MSSQL_USER2·PASSWORD2 필수
# 기본: Sp_Inventory_NQL 에 조회일(YYYYMMDD) 한 매개 변수만 전달. 레거시(#BIZ_* + _SWLGWHStockListQuery)는 아래를 false/0/no/legacy
# ERP_WH_STOCK_LIST_USE_SP_INVENTORY_NQL=false
# ERP_WH_STOCK_LIST_SP_INVENTORY_NQL_PROC=Sp_Inventory_NQL
# SP 매개 변수 이름( @ 제외, ERP 정의와 동일하게 ). 기본 Date → 값은 YYYYMMDD 8자(하이픈 없음)
# ERP_WH_STOCK_LIST_SP_INVENTORY_NQL_DATE_PARAM=Date
# 조회일 전달 형식: char8(YYYYMMDD 문자) | date(datetime). 기본 char8
# ERP_WH_STOCK_LIST_SP_INVENTORY_NQL_DATE_SQL_TYPE=char8
# ERP_WH_STOCK_LIST_BATCH_PROC=_SWLGWHStockListQuery
# ERP_WH_STOCK_LIST_RUN_PROC_CHECK=false
# ERP_WH_STOCK_LIST_SERVICE_SEQ=501534
# ERP_WH_STOCK_LIST_METHOD_SEQ=1
# ERP_WH_STOCK_LIST_PGM_SEQ=501179
# ERP_WH_STOCK_LIST_COMPANY_SEQ=1
# ERP_WH_STOCK_LIST_LANGUAGE_SEQ=1
# ERP_WH_STOCK_LIST_USER_SEQ=5
# ERP_WH_STOCK_LIST_BIZ_UNIT=1
# ERP_WH_STOCK_LIST_SM_QRY_TYPE=S
# ERP_WH_STOCK_LIST_SMWH_TYPE=8104001
# ERP_WH_STOCK_LIST_SM_UNIT_TYPE=8103001
# ERP_WH_STOCK_LIST_IS_STOCK_AMT=1
# ERP_WH_STOCK_LIST_SMWH_KIND=
# ERP_WH_STOCK_LIST_WH_SEQ=
# 엑셀과 동일한 창고 열 순서(선택). JSON 배열 문자열. 비우면 코드 기본 15창고 순서 사용.
# ERP_WH_STOCK_LIST_EXCEL_WH_HEADERS=["개발창고","경유창고","부자재창고","사출창고","사출창고(불)","세인테크","원자재창고","제품창고","조립창고","조립창고(불)","청야텍(삼광)","태령기업","품_시료창고(불)","MCT창고","MCT창고(불)"]
