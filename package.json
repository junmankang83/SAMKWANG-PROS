{
  "name": "samkwang-pros",
  "version": "0.1.0",
  "private": true,
  "description": "SAMKWANG-PROS - 생산관리시스템 (NestJS + Next.js + PostgreSQL 모노레포)",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build:shared": "pnpm --filter @samkwang/shared build",
    "build:backend": "pnpm --filter @samkwang/backend build",
    "build:frontend": "pnpm --filter @samkwang/frontend build",
    "build": "pnpm build:shared && pnpm -r --filter='!@samkwang/shared' build",
    "dev:backend": "pnpm --filter @samkwang/backend start:dev",
    "dev:frontend": "pnpm --filter @samkwang/frontend dev",
    "lint": "pnpm -r lint",
    "compose:up": "docker compose up --build",
    "compose:up:detached": "docker compose up --build -d",
    "compose:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "compose:dev:detached": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "compose:ps": "docker compose ps",
    "prisma:migrate": "docker compose exec backend pnpm prisma migrate dev",
    "prisma:studio": "docker compose exec backend pnpm prisma studio --port 5555 --hostname 0.0.0.0"
  }
}
